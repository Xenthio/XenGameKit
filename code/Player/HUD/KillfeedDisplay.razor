@using Sandbox;
@using Sandbox.UI;
@inherits Panel

@* Source-style killfeed. Reads from KillfeedData — populated by BaseGamemode.BroadcastKill.
   Entries fade out after EntryLifetime seconds.
   No setup needed — just add <killfeed></killfeed> to your HUD. *@

<root class="Killfeed">
	@foreach ( var entry in Entries() )
	{
		<div class="KillfeedEntry" style="opacity: @(Opacity(entry));">
			<label class="KillerName">@entry.Killer</label>
			@if ( !string.IsNullOrEmpty( entry.Weapon ) )
			{
				<label class="WeaponName">[@entry.Weapon]</label>
			}
			<label class="VictimName">@entry.Victim</label>
		</div>
	}
</root>

@code
{
	const float EntryLifetime = 6f;

	// Prune expired entries and return the live ones. Called every BuildHash tick.
	IEnumerable<KillfeedData.Entry> Entries()
	{
		KillfeedData.Prune( EntryLifetime );
		return KillfeedData.Entries;
	}

	float Opacity( KillfeedData.Entry e ) => MathX.Clamp( EntryLifetime - e.Age, 0f, 1f );

	// Rebuild every frame while there are entries so opacity animates smoothly.
	protected override int BuildHash() =>
		HashCode.Combine( KillfeedData.Entries.Count, (int)(RealTime.Now * 4f) );
}
